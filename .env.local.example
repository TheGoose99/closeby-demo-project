# CLIENT — selectează config din config/clients/
CLIENT_SLUG=demo

# RESEND — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# (Optional) Sender email address for Resend
RESEND_FROM=noreply@closeby.studio

# CAL.COM WEBHOOK — https://cal.com/settings/developer/webhooks
CAL_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx

# CAL.COM API (server-only) — used to decline duplicate booking requests
# Create in Cal.com -> Settings -> Developer -> API Keys
CAL_API_KEY=cal_xxxxxxxxxxxxxxxxxxxxxx

# CAL.COM PUBLIC INTEGRATION (non-secret, used by booking embed)
# Keep these per deployment/client. They override config/clients/*.ts fallback values.
NEXT_PUBLIC_CAL_COM_USERNAME=
# JSON object with keys: initial, session, couple
NEXT_PUBLIC_CAL_COM_CANONICAL_EVENT_SLUGS_JSON=
# Optional JSON override object with keys: initial, session, couple
NEXT_PUBLIC_CAL_COM_EVENT_SLUGS_JSON=

# GOOGLE MAPS — https://console.cloud.google.com (Maps Embed API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SITE URL
NEXT_PUBLIC_SITE_URL=https://ana-ionescu-psiholog.ro
# Optional: extra allowed hosts for /api/booking/verify-phone Origin checks (comma-separated URLs or hostnames)
# BOOKING_VERIFY_ALLOWED_HOSTS=www.example.com,preview.example.com
# Optional: comma-separated full origins (https://...) — hostnames are extracted
# BOOKING_VERIFY_ALLOWED_ORIGINS=https://www.example.com,https://staging.example.com
# Emergency escape hatch (NOT recommended): allow verify-phone without explicit allowed hosts in production
# BOOKING_VERIFY_TRUST_ANY_ORIGIN=1
# Sec-Fetch-Site enforcement for verify-phone (production): strict | relaxed | off (default: strict)
# BOOKING_VERIFY_FETCH_SITE_MODE=strict
# Optional: require CLIENT_SLUG to be set in production (defense-in-depth vs misconfigured deployments)
# BOOKING_VERIFY_REQUIRE_CLIENT_SLUG=1
# Optional: Redis-backed rate limits for verify-phone (requires KV_* or UPSTASH_* Redis REST env vars)
# BOOKING_VERIFY_RL_WINDOW_SECONDS=900
# BOOKING_VERIFY_RL_MAX_PER_WINDOW=8
# BOOKING_VERIFY_RL_MAX_PER_IP_PER_WINDOW=40

# QSTASH (Upstash) — reliable delayed jobs on Vercel
QSTASH_TOKEN=
# Optional: forwarded Authorization header for job routes
QSTASH_FORWARD_SECRET=

# UPSTASH REDIS (REST) — durable phone lock + idempotency
# If using the Vercel ↔ Upstash integration, these are usually provided as:
# KV_REST_API_URL / KV_REST_API_TOKEN
KV_REST_API_URL=
KV_REST_API_TOKEN=

# SUPABASE (tenant data source / integrations)
# Point to the project where you applied migrations from **seo-data-platform** (`supabase/migrations/` there).
# DDL is not run from this repo.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Row lookup in `public.clients.client_slug` (defaults to static `config/clients/*.ts` slug if unset)
SUPABASE_TENANT_CLIENT_SLUG=
# Optional: resolve Cal webhook/API secrets for this slug even if CLIENT_SLUG differs (shared webhook URL)
WEBHOOK_TENANT_CLIENT_SLUG=
# Set to 1 to skip resolving tenant from Cal payload.organizer.username (use only env/static slug for secrets)
WEBHOOK_SKIP_CAL_USERNAME_LOOKUP=
# Set to 1 to log JSON lines for integration source (merged config + webhook tenant resolution)
DEBUG_INTEGRATION_SOURCE=

# Cross-project phone lock bridge (closeby -> seo-data-platform)
SEO_DATA_PLATFORM_URL=
INTERNAL_LOCK_API_TOKEN=
# Optional: force token requirement even in non-production (matches seo-data-platform strict mode)
# INTERNAL_LOCK_API_TOKEN_REQUIRED=1

# Firebase — phone verification before booking (client SDK + Admin verify on server)
# Create a Web App in Firebase console and copy the web config here.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional: Firebase App Check (reCAPTCHA v3 public site key — same key registered in Firebase Console → App Check with secret)
# Domains allowed in reCAPTCHA v3 admin must include every origin you use (e.g. ngrok host + production host).
# NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=
# Enforce App Check on /api/booking/verify-phone (server verifies token via Firebase Admin)
# FIREBASE_APPCHECK_ENFORCE=1
# Firebase Admin: paste the full service account JSON as a single line (Vercel-friendly)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Legacy/debug: public phone-lock API (prefer verify-phone). In production this route is disabled unless:
# - ENABLE_PUBLIC_PHONE_LOCK_API=1, OR
# - request includes header x-phone-lock-token matching PHONE_LOCK_API_TOKEN
# ENABLE_PUBLIC_PHONE_LOCK_API=1
# PHONE_LOCK_API_TOKEN=
